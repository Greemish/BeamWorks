{
  "buildCommand": "node build-env.js",
  "outputDirectory": "Frontend",
  "cleanUrls": true,
  "routes": [
    { "src": "/admin/?$", "dest": "/Admin.html" },
    { "src": "/Admin/?$", "dest": "/Admin.html" },
    { "src": "/shop/?$", "dest": "/shop.html" },
    { "src": "/product/?$", "dest": "/product.html" },
    { "src": "/checkout/?$", "dest": "/checkout.html" },
    { "src": "/promotions/?$", "dest": "/promotions.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
